# minion configuration
# Copy to config.yaml and adjust to your needs.
# The pipeline also accepts repos.json for backward compatibility.

# Repositories to process
repos:
  - owner: my-org
    name: my-repo
    defaultBranch: main
    testCommand: pnpm test
  - owner: my-org
    name: another-repo
    defaultBranch: develop
    testCommand: npm test

# Maximum number of issues to process per run (default: 10)
maxIssuesPerRun: 10

# MAP (multi-agent-pipeline) configuration
# mapModel: claude-sonnet-4-5      # Model MAP uses internally (optional)
# mapTimeoutMs: 1800000            # Timeout in milliseconds (default: 30 minutes)

# Retry configuration for failed issues
retry:
  maxAttempts: 3        # max retries per issue (default: 3)
  backoffMinutes: 60    # minimum wait between retries (default: 60)

# Auto-merge settings
# When a user comments the trigger phrase on a pipeline-created PR,
# the pipeline will rebase the branch and merge it on the next run.
mergeCommentTrigger: '/merge'     # comment text that triggers merge (default: '/merge')
mergeMethod: merge                # merge | squash | rebase (default: merge)
mergeDraftPRs: false              # allow merging draft PRs (default: false)
autoMerge: true                   # AI auto-review and merge open PRs (default: true)
autoMergeRequireTests: true       # require tests to pass before auto-merge (default: true)

# Poll loop failsafes (only apply when running with --poll)
# maxPollRuns: 100              # stop after N poll iterations (default: unlimited)
maxConsecutiveFailures: 5         # stop after N consecutive failed runs (default: 5)
